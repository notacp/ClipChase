{
  "manifest_version": 3,
  "name": "TimeStitch",
  "version": "1.0.0",
  "description": "Search YouTube channel transcripts for keywords.",
  "permissions": ["sidePanel"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://api.timestitch.app/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "Open TimeStitch"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
