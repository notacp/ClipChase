{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "fluid": true,
    "buildCommand": "npm install --include=dev && npm run build",
    "outputDirectory": ".next",
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api/index" }
    ],
    "functions": {
        "api/index.py": {
            "maxDuration": 300,
            "memory": 1024
        }
    }
}
